{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.dev/schemas/movie-pipeline/v3",
  "title": "Movie Pipeline V3 Data Contract",
  "description": "Global data schema for AI movie production pipeline V3 — all skills communicate through these models.",
  "definitions": {
    "typed": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "required": [
        "type",
        "version"
      ]
    },
    "ConceptArtifact": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ConceptArtifact"
            },
            "topic": {
              "type": "string",
              "minLength": 1
            },
            "genre": {
              "type": "string"
            },
            "target_audience": {
              "type": "string"
            },
            "hooks": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "estimated_duration": {
              "type": "number",
              "minimum": 0,
              "description": "seconds"
            },
            "quality_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "required": [
            "type",
            "version",
            "topic",
            "genre",
            "target_audience",
            "hooks",
            "estimated_duration",
            "quality_score"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "ConceptArtifact"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "StoryBeat": {
      "type": "object",
      "properties": {
        "beat_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "emotional_arc": {
          "type": "string"
        }
      },
      "required": [
        "beat_id",
        "name",
        "description",
        "sequence"
      ]
    },
    "StoryDNA": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "StoryDNA"
            },
            "logline": {
              "type": "string",
              "minLength": 1
            },
            "synopsis": {
              "type": "string",
              "minLength": 1
            },
            "beats": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/StoryBeat"
              }
            },
            "characters": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "character_id references"
            },
            "theme": {
              "type": "string"
            },
            "tone": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "version",
            "logline",
            "synopsis",
            "beats",
            "characters",
            "theme",
            "tone"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "StoryDNA"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "CharacterBible": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "CharacterBible"
            },
            "character_id": {
              "type": "string",
              "pattern": "^char_[a-z0-9_]+$"
            },
            "name": {
              "type": "string"
            },
            "appearance": {
              "type": "string"
            },
            "personality": {
              "type": "string"
            },
            "reference_images": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              }
            },
            "seed": {
              "type": "integer"
            },
            "consistency_lock": {
              "type": "object",
              "properties": {
                "locked": {
                  "type": "boolean",
                  "default": false
                },
                "lock_version": {
                  "type": "integer",
                  "default": 0
                },
                "frozen_fields": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "locked"
              ]
            }
          },
          "required": [
            "type",
            "version",
            "character_id",
            "name",
            "appearance",
            "personality",
            "reference_images",
            "seed",
            "consistency_lock"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "CharacterBible"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "CameraPosition": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        },
        "look_at": {
          "type": "string"
        },
        "lens": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "SceneDesign": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "SceneDesign"
            },
            "scene_id": {
              "type": "string",
              "pattern": "^scene_[a-z0-9_]+$"
            },
            "location": {
              "type": "string"
            },
            "zones": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "camera_positions": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CameraPosition"
              }
            },
            "atmosphere": {
              "type": "string"
            },
            "lighting": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "version",
            "scene_id",
            "location",
            "zones",
            "camera_positions",
            "atmosphere",
            "lighting"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "SceneDesign"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "ArtDirection": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ArtDirection"
            },
            "style_name": {
              "type": "string"
            },
            "color_palette": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^#[0-9a-fA-F]{6}$"
              },
              "minItems": 3
            },
            "light_quality": {
              "type": "string"
            },
            "texture": {
              "type": "string"
            },
            "composition_rules": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reference_images": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              }
            }
          },
          "required": [
            "type",
            "version",
            "style_name",
            "color_palette",
            "light_quality",
            "texture",
            "composition_rules",
            "reference_images"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "ArtDirection"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "Shot": {
      "type": "object",
      "properties": {
        "shot_id": {
          "type": "string",
          "pattern": "^shot_[a-z0-9_]+$"
        },
        "scene_ref": {
          "type": "string"
        },
        "character_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "camera": {
          "type": "object",
          "properties": {
            "angle": {
              "type": "string"
            },
            "movement": {
              "type": "string"
            },
            "lens": {
              "type": "string"
            }
          },
          "required": [
            "angle"
          ]
        },
        "action": {
          "type": "string"
        },
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "reference_image": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "shot_id",
        "scene_ref",
        "character_refs",
        "camera",
        "action",
        "duration"
      ]
    },
    "Storyboard": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "Storyboard"
            },
            "shots": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Shot"
              },
              "minItems": 1
            }
          },
          "required": [
            "type",
            "version",
            "shots"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "Storyboard"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "JimengApiParams": {
      "type": "object",
      "properties": {
        "model": { "type": "string", "description": "即梦模型名，如 jimeng-video-seedance-2.0-fast, jimeng-video-3.5-pro, jimeng-5.0" },
        "prompt": { "type": "string", "minLength": 1 },
        "ratio": { "type": "string", "enum": ["16:9", "9:16", "1:1", "4:3", "21:9"] },
        "duration": { "type": "number", "minimum": 1, "description": "秒" },
        "file_paths": { "type": "array", "items": { "type": "string", "format": "uri" }, "description": "Seedance 素材图片 URL" },
        "resolution": { "type": "string", "description": "图片分辨率，如 2k" }
      },
      "required": ["model", "prompt"]
    },
    "VideoShot": {
      "type": "object",
      "properties": {
        "shot_id": { "type": "string" },
        "seed": { "type": "integer" },
        "aspect_ratio": { "type": "string", "enum": ["16:9", "9:16", "1:1", "4:3", "21:9"] },
        "motion_strength": { "type": "number", "minimum": 0, "maximum": 10 },
        "api_params": { "$ref": "#/definitions/JimengApiParams", "description": "即梦 API 直接可用的参数" },
        "fallback": { "$ref": "#/definitions/JimengApiParams", "description": "降级方案（纯文本模型）" },
        "character_refs": { "type": "array", "items": { "type": "string" } },
        "scene_ref": { "type": "string" },
        "camera": {
          "type": "object",
          "properties": { "angle": { "type": "string" }, "movement": { "type": "string" }, "lens": { "type": "string" } }
        },
        "mode": { "type": "string", "enum": ["video", "image"] },
        "attempt": { "type": "integer", "minimum": 1 }
      },
      "required": ["shot_id", "api_params", "fallback"]
    },
    "ShootingScript": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ShootingScript"
            },
            "shots": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/VideoShot"
              },
              "minItems": 1
            }
          },
          "required": [
            "type",
            "version",
            "shots"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "ShootingScript"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "EvolutionState": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "EvolutionState"
            },
            "population": {
              "type": "array",
              "items": {}
            },
            "generation": {
              "type": "integer",
              "minimum": 0
            },
            "fitness_scores": {
              "type": "array",
              "items": {
                "type": "number"
              }
            },
            "selected": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "convergence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": [
            "type",
            "version",
            "population",
            "generation",
            "fitness_scores",
            "selected",
            "convergence_threshold"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "EvolutionState"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    },
    "ProjectManifest": {
      "allOf": [
        {
          "$ref": "#/definitions/typed"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ProjectManifest"
            },
            "project_id": {
              "type": "string"
            },
            "concept": {
              "$ref": "#/definitions/ConceptArtifact"
            },
            "story": {
              "$ref": "#/definitions/StoryDNA"
            },
            "characters": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/CharacterBible"
              }
            },
            "scenes": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/SceneDesign"
              }
            },
            "art_direction": {
              "$ref": "#/definitions/ArtDirection"
            },
            "storyboard": {
              "$ref": "#/definitions/Storyboard"
            },
            "shooting_script": {
              "$ref": "#/definitions/ShootingScript"
            },
            "evolution_state": {
              "$ref": "#/definitions/EvolutionState"
            }
          },
          "required": [
            "type",
            "version",
            "project_id"
          ]
        }
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "ProjectManifest"
        },
        "version": {
          "type": "string",
          "const": "3.0"
        }
      }
    }
  }
}